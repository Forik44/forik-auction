@inherits LayoutComponentBase

<div class="sakura" aria-hidden="true">
    @for (int i = 0; i < 12; i++) { <span class="petal">🌸</span> }
</div>

<div class="app-shell">
    <header class="topbar">
        <a class="brand" href="/">🌸 Аниме-Аукцион</a>
        <div class="spacer"></div>
        <AuthorizeView>
            <Authorized>
                <span class="user">@context.User.Identity?.Name</span>
                <form action="/auth/logout" method="post" style="display:inline">
                    <button class="btn ghost" type="submit">Выйти</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a class="btn primary" href="/auth/login">Войти через Google</a>
            </NotAuthorized>
        </AuthorizeView>
    </header>
    <main class="content">
        @Body
    </main>
</div>

<img class="mascot" src="img/mascot.svg" alt="" aria-hidden="true" />
